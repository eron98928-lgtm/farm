{
  "name": "manga-platform-backend",
  "version": "1.0.0",
  "description": "Backend seguro para plataforma de leitura de mangás",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "db:generate": "drizzle-kit generate:mysql --schema=src/db/schema.ts --out=./drizzle/migrations",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "manga",
    "trpc",
    "express",
    "security"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "@pinecone-database/pinecone": "^2.0.0",
    "@sentry/node": "^10.53.1",
    "@trpc/client": "^10.0.0",
    "@trpc/server": "^10.0.0",
    "@types/pg": "^8.20.0",
    "@upstash/redis": "^1.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.21.0",
    "posthog-node": "^3.0.0",
    "resend": "^2.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/morgan": "^1.9.0",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
