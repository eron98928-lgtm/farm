{
  "version": 2,
  "outputDirectory": "frontend",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node",
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/health",   "destination": "/api/index.ts" }
  ]
}
